{
  "version": 2,
  "builds": [
    {
      "src": "src/server.ts",
      "use": "@vercel/node"
    }
  ,
  "headers": [
    {
      "source": "\\/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://nicolas-dominici.it" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,POST,PUT,DELETE" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ]
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.ts"
    }
  ]
}